---
import MainLayout from '../layouts/MainLayout.astro';
import gtaData from '../data/gta-weekly.json';
---

<MainLayout title="GTA Bonuses">
  <div class="max-w-6xl mx-auto py-8 md:py-12 px-4 md:px-6">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-10 gap-6">
        <div class="w-full md:w-auto">
            <h1 class="text-[clamp(32px,10vw,72px)] tracking-tighter uppercase font-black italic leading-none">GTA Bonuses</h1>
            <p class="text-zinc-500 text-sm md:text-lg italic tracking-wide mt-2">Valid through {gtaData.weekEnding}</p>
        </div>
        
        <div class="flex flex-col items-start md:items-end gap-3 w-full md:w-auto">
            <div class="bg-gold/10 border border-gold/20 px-4 py-2 rounded-lg w-fit">
                <p class="text-[9px] uppercase font-bold text-gold tracking-[0.3em]">FIB Priority File</p>
                <p class="text-white font-black uppercase text-xs mt-1">{gtaData.fibFile}</p>
            </div>
            <div class="bg-blue-500/10 border border-blue-500/20 px-4 py-2 rounded-lg w-fit">
                <p class="text-[9px] uppercase font-bold text-blue-400 tracking-[0.3em]">New Livery</p>
                <p class="text-white font-black uppercase text-xs mt-1 italic font-bold text-blue-100">Water Like (FMJ MK V)</p>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mb-16">
      {gtaData.bonuses.map((bonus) => (
        <div class="bg-zinc-900/50 p-6 rounded-xl border border-zinc-800 hover:border-gold transition-all group">
          <span class="text-[10px] uppercase tracking-widest text-gold font-bold">{bonus.category}</span>
          <h2 class="text-lg font-bold mt-1 text-white leading-tight">{bonus.name}</h2>
          <p class="text-4xl font-black text-gold mt-2 tracking-tighter">{bonus.value}</p>
        </div>
      ))}
    </div>

    <div class="mb-16">
        <h2 class="text-2xl mb-6 uppercase font-black tracking-tighter flex items-center gap-2 px-2">
            <i data-lucide="gift" class="text-gold"></i> Limited Time Unlocks
        </h2>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-3">
            {gtaData.unlocks.map((item) => (
                <div class="bg-zinc-900 border-t-2 border-gold p-4 rounded-xl shadow-lg">
                    <p class="text-[9px] uppercase font-bold text-zinc-500 tracking-widest leading-tight mb-1">{item.requirement}</p>
                    <p class="text-white font-black text-[10px] md:text-xs uppercase tracking-tighter">{item.title}</p>
                </div>
            ))}
        </div>
    </div>

    </div>
</MainLayout>