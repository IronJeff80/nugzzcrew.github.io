---
import MainLayout from '../layouts/MainLayout.astro';

// Data pulled specifically from your CSV "Obtainable" == FALSE categories
const primaryUnselected = ["Custom RGB", "Pure White", "Modded Blue", "Modded Green", "Secret Gold", "MP100", "Chrome", "Black", "Blue", "Brown", "Dark Blue", "Dark Earth", "Dark Red", "Desert Tan", "Foliage Green", "Gray", "Green", "Hot Pink", "Lime Green", "Orange", "Pink", "Purple", "Red", "White", "Yellow"];
const secondaryUnselected = ["Custom RGB", "Pure White", "Secret Gold", "MP100", "Chrome", "Black", "Blue", "Brown", "Dark Blue", "Dark Earth", "Dark Red", "Desert Tan", "Foliage Green", "Gray", "Green", "Hot Pink", "Lime Green", "Orange", "Pink", "Purple", "Red", "White", "Yellow"];
const pearlUnselected = ["Pure White", "Secret Gold", "MP100", "Chrome", "Black", "Blue", "Brown", "Dark Blue", "Dark Earth", "Dark Red", "Desert Tan", "Foliage Green", "Gray", "Green", "Hot Pink", "Lime Green", "Orange", "Pink", "Purple", "Red", "White", "Yellow"];
const rimUnselected = ["Pure White", "Secret Gold", "MP100", "Chrome", "Black", "Blue", "Brown", "Dark Blue", "Dark Earth", "Dark Red", "Desert Tan", "Foliage Green", "Gray", "Green", "Hot Pink", "Lime Green", "Orange", "Pink", "Purple", "Red", "White", "Yellow"];
const interiorUnselected = ["Pure White", "Secret Gold", "MP100", "Chrome", "Black", "Blue", "Brown", "Dark Blue", "Dark Earth", "Dark Red", "Desert Tan", "Foliage Green", "Gray", "Green", "Hot Pink", "Lime Green", "Orange", "Pink", "Purple", "Red", "White", "Yellow"];

const textures = ["MP100(Super Shiny)", "Other(Shiny)", "Brushed(Shiny/Matte)", "Matte", "Worn"];
const tireDesigns = ["None", "White lines", "Classic", "Retro", "Red", "Blue"];
const headlightColors = ["Default", "Pure White", "Blue", "Electric Blue", "Mint Green", "Lime Green", "Yellow", "Golden Shower", "Orange", "Red", "Poncho Pink", "Hot Pink", "Purple", "Blacklight"];
---

<MainLayout title="DMO Generator">
  <div class="max-w-5xl mx-auto px-4 py-12">
    <div class="mb-10 text-center">
      <h1 class="text-4xl font-header text-gold uppercase tracking-tighter mb-2">DMO Generator</h1>
      <p class="text-zinc-400 uppercase text-xs tracking-[0.2em]">Follow the order and build your spec</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
      <div class="lg:col-span-7 bg-zinc-900/40 p-6 rounded-3xl border border-zinc-800 space-y-6">
        
        <div class="space-y-4">
          <div>
            <label class="block text-[10px] text-zinc-500 uppercase font-black mb-1">Vehicle or Set:</label>
            <input type="text" id="vehicle" placeholder="e.g. Buffalo STX" class="w-full bg-black border border-zinc-800 rounded-lg p-2.5 text-white text-sm outline-none focus:border-gold" />
          </div>

          <div>
            <label class="block text-[10px] text-zinc-500 uppercase font-black mb-1">Plate Text (8 characters):</label>
            <input type="text" id="plate" maxlength="8" placeholder="NUGZZ" class="w-full bg-black border border-zinc-800 rounded-lg p-2.5 text-white text-sm uppercase font-mono outline-none focus:border-gold" />
          </div>

          <div>
            <label class="block text-[10px] text-zinc-500 uppercase font-black mb-1">Windows Tint (Clear or Green):</label>
            <select id="windows" class="w-full bg-black border border-zinc-800 rounded-lg p-2.5 text-white text-sm outline-none focus:border-gold">
              <option value="Clear">Clear</option>
              <option value="Green">Green</option>
            </select>
          </div>

          <div>
            <label class="block text-[10px] text-zinc-500 uppercase font-black mb-1">Headlight Color NO RGB:</label>
            <select id="headlights" class="w-full bg-black border border-zinc-800 rounded-lg p-2.5 text-white text-sm outline-none focus:border-gold">
              {headlightColors.map(h => <option value={h}>{h}</option>)}
            </select>
          </div>

          <div>
            <label class="block text-[10px] text-zinc-500 uppercase font-black mb-1">Neon Color or RGB:</label>
            <input type="text" id="neon" placeholder="e.g. Pure White or 255, 255, 255" class="w-full bg-black border border-zinc-800 rounded-lg p-2.5 text-white text-sm outline-none focus:border-gold" />
          </div>

          <div>
            <label class="block text-[10px] text-zinc-500 uppercase font-black mb-1">Paint Texture:</label>
            <select id="texture" class="w-full bg-black border border-zinc-800 rounded-lg p-2.5 text-white text-sm outline-none focus:border-gold">
              {textures.map(t => <option value={t}>{t}</option>)}
            </select>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-[10px] text-zinc-500 uppercase font-black mb-1">Primary Color or RGB:</label>
              <select id="primary" class="w-full bg-black border border-zinc-800 rounded-lg p-2.5 text-white text-sm outline-none focus:border-gold">
                {primaryUnselected.map(c => <option value={c}>{c}</option>)}
              </select>
            </div>
            <div>
              <label class="block text-[10px] text-zinc-500 uppercase font-black mb-1">Secondary Color or RGB:</label>
              <select id="secondary" class="w-full bg-black border border-zinc-800 rounded-lg p-2.5 text-white text-sm outline-none focus:border-gold">
                {secondaryUnselected.map(c => <option value={c}>{c}</option>)}
              </select>
            </div>
          </div>

          <div id="rgbInputArea" class="hidden">
            <label class="block text-[10px] text-gold uppercase font-black mb-1">Enter Shared RGB (255, 255, 255):</label>
            <input type="text" id="customRgb" placeholder="0, 0, 0" class="w-full bg-black border border-gold/50 rounded-lg p-2.5 text-white text-sm outline-none" />
          </div>

          <div>
            <label class="block text-[10px] text-zinc-500 uppercase font-black mb-1">Pearlescent Color NO RGB:</label>
            <select id="pearl" class="w-full bg-black border border-zinc-800 rounded-lg p-2.5 text-white text-sm outline-none focus:border-gold">
              {pearlUnselected.map(c => <option value={c}>{c}</option>)}
            </select>
          </div>

          <div>
            <label class="block text-[10px] text-zinc-500 uppercase font-black mb-1">Interior Color NO RGB:</label>
            <select id="interior" class="w-full bg-black border border-zinc-800 rounded-lg p-2.5 text-white text-sm outline-none focus:border-gold">
              {interiorUnselected.map(c => <option value={c}>{c}</option>)}
            </select>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-[10px] text-zinc-500 uppercase font-black mb-1">Rim Style:</label>
              <input type="text" id="rimStyle" placeholder="e.g. Bennys Bespoke" class="w-full bg-black border border-zinc-800 rounded-lg p-2.5 text-white text-sm outline-none focus:border-gold" />
            </div>
            <div>
              <label class="block text-[10px] text-zinc-500 uppercase font-black mb-1">Rim Color NO RGB:</label>
              <select id="rimColor" class="w-full bg-black border border-zinc-800 rounded-lg p-2.5 text-white text-sm outline-none focus:border-gold">
                {rimUnselected.map(c => <option value={c}>{c}</option>)}
              </select>
            </div>
          </div>

          <div>
            <label class="block text-[10px] text-zinc-500 uppercase font-black mb-1">Tire Design:</label>
            <select id="tires" class="w-full bg-black border border-zinc-800 rounded-lg p-2.5 text-white text-sm outline-none focus:border-gold">
              {tireDesigns.map(d => <option value={d}>{d}</option>)}
            </select>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-[10px] text-zinc-500 uppercase font-black mb-1">Horn:</label>
              <input type="text" id="horn" placeholder="e.g. San Andreas" class="w-full bg-black border border-zinc-800 rounded-lg p-2.5 text-white text-sm outline-none focus:border-gold" />
            </div>
            <div>
              <label class="block text-[10px] text-zinc-500 uppercase font-black mb-1">Livery:</label>
              <input type="text" id="livery" placeholder="e.g. Flaming Skull" class="w-full bg-black border border-zinc-800 rounded-lg p-2.5 text-white text-sm outline-none focus:border-gold" />
            </div>
          </div>
        </div>

        <button id="generateBtn" class="w-full bg-gold hover:bg-white text-black font-black uppercase py-4 rounded-xl tracking-widest transition-all">
          Generate DMO Spec
        </button>
      </div>

      <div class="lg:col-span-5">
        <div class="sticky top-24">
          <div class="bg-black border-2 border-dashed border-zinc-800 rounded-3xl p-6 flex flex-col">
            <span class="text-[10px] text-zinc-500 uppercase font-black tracking-widest mb-4">Discord Ready Output:</span>
            <textarea id="output" readonly class="bg-transparent font-mono text-sm h-[500px] w-full resize-none outline-none border-none" style="color: #D4AF37;" placeholder="Waiting for build..."></textarea>
            <button id="copyBtn" class="mt-6 w-full bg-zinc-800 hover:bg-zinc-700 text-white font-bold uppercase py-4 rounded-xl tracking-widest transition-all">
              Copy To Clipboard
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</MainLayout>

<script>
  const generateBtn = document.getElementById('generateBtn');
  const primarySel = document.getElementById('primary') as HTMLSelectElement;
  const secondarySel = document.getElementById('secondary') as HTMLSelectElement;
  const rgbArea = document.getElementById('rgbInputArea');

  // Toggle RGB input if "Custom RGB" is selected in either paint slot
  const checkRgb = () => {
    if (primarySel.value === "Custom RGB" || secondarySel.value === "Custom RGB") {
      rgbArea.classList.remove('hidden');
    } else {
      rgbArea.classList.add('hidden');
    }
  };

  primarySel.addEventListener('change', checkRgb);
  secondarySel.addEventListener('change', checkRgb);

  generateBtn.addEventListener('click', () => {
    const getData = (id: string) => (document.getElementById(id) as HTMLInputElement | HTMLSelectElement).value;
    
    const customRgb = (document.getElementById('customRgb') as HTMLInputElement).value;
    const pVal = primarySel.value === "Custom RGB" ? `RGB (${customRgb})` : primarySel.value;
    const sVal = secondarySel.value === "Custom RGB" ? `RGB (${customRgb})` : secondarySel.value;

    const spec = `**🚀 DMO SPEC SHEET**
────────────────────
🚘 **Vehicle or Set:** ${getData('vehicle')}
📟 **Plate Text:** ${getData('plate')}
🪟 **Windows Tint:** ${getData('windows')}
💡 **Headlight Color:** ${getData('headlights')}
🌈 **Neon Color or RGB:** ${getData('neon')}
🎨 **Paint Texture:** ${getData('texture')}
🖌️ **Primary Color:** ${pVal}
🖌️ **Secondary Color:** ${sVal}
✨ **Pearlescent Color:** ${getData('pearl')}
🛋️ **Interior Color:** ${getData('interior')}
🛞 **Rim Style:** ${getData('rimStyle')}
🎨 **Rim Color:** ${getData('rimColor')}
🏁 **Tire Design:** ${getData('tires')}
📢 **Horn:** ${getData('horn')}
📜 **Livery:** ${getData('livery')}
────────────────────
*OfficialNugzzCrew.com*`;

    (document.getElementById('output') as HTMLTextAreaElement).value = spec;
  });

  document.getElementById('copyBtn').addEventListener('click', () => {
    const out = document.getElementById('output') as HTMLTextAreaElement;
    out.select();
    document.execCommand('copy');
    alert('Copied to Clipboard!');
  });
</script>