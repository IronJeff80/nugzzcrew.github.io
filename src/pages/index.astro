---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Home">
  <section class="max-w-4xl mx-auto py-20 px-6 text-center">
    <h1 class="text-6xl mb-4 tracking-wider">
      Official Nugzz Crew
    </h1>
    <p class="text-xl text-zinc-400 mb-10 italic">"Streaming, GTA Updates, and the best community in the game."</p>
    
    <!-- Stream Container with Background Image -->
    <div 
      class="relative aspect-video w-full rounded-2xl border border-zinc-800 mb-12 overflow-hidden shadow-[0_0_50px_-12px_rgba(212,175,55,0.3)] bg-cover bg-center"
      style="background-image: url('/offline.png');"
    >
      <!-- The YouTube Embed sits on top -->
      <!-- If the stream is live, the thumbnail/video covers the background automatically -->
      <iframe 
        class="absolute top-0 left-0 w-full h-full z-10"
        src="https://www.youtube.com/embed/live_stream?channel=UCYNmnbEgm3G0m4avmwz_4Eg" 
        title="Official Nugzz Crew Live Stream" 
        frameborder="0" 
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
        allowfullscreen>
      </iframe>

      <!-- Optional: A subtle Gold overlay that only shows if the iframe is transparent/empty -->
      <div class="absolute inset-0 bg-black/40 flex items-end justify-start p-6 pointer-events-none">
         <span class="flex items-center gap-2 text-gold font-bold uppercase text-xs tracking-[0.2em]">
            <span class="w-2 h-2 bg-gold rounded-full animate-pulse"></span>
            Live Feed
         </span>
      </div>
    </div>

    <div class="grid md:grid-cols-2 gap-6 mt-12">
      <a href="/gta" class="p-8 bg-zinc-900 border border-zinc-800 rounded-2xl hover:border-gold transition-all group text-left">
        <h2 class="text-2xl group-hover:text-gold-bright transition-colors uppercase">GTA Weekly Updates &rarr;</h2>
        <p class="text-zinc-500 mt-2">Get the latest on bonuses, car meets, and robberies.</p>
      </a>

      <div class="p-8 bg-zinc-900 border border-zinc-800 rounded-2xl text-left">
        <h2 class="text-2xl uppercase font-header text-gold">The Fam Bam</h2>
        <p class="text-zinc-500 mt-2">Catch every live stream and join the best community on YouTube.</p>
      </div>
    </div>
  </section>
</MainLayout>