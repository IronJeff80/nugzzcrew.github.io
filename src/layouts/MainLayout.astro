---
const { title = "Nugzz Crew Terminal" } = Astro.props;

// Centralized navigation links for seamless multi-game expansion
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/gta', label: 'GTA Weekly' },
  { href: '/gtaresources', label: 'DMO Gen & Maps' }
];
---

<!DOCTYPE html>
<html lang="en" class="bg-black text-white selection:bg-gold selection:text-black">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <script src="https://unpkg.com/lucide@latest"></script>
  </head>
  <body class="min-h-screen bg-black antialiased flex flex-col font-sans">
    
    <header class="w-full border-b border-zinc-800 bg-zinc-900/40 backdrop-blur-md sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 py-4 flex flex-col sm:flex-row items-center justify-between gap-4">
        
        <a href="/" class="flex items-center gap-2 group shrink-0">
          <span class="font-black text-xl tracking-tighter text-white uppercase group-hover:text-gold transition-colors">
            NUGZZ<span class="text-gold group-hover:text-white transition-colors">CREW</span>
          </span>
        </a>

        <nav class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2">
          {navLinks.map(link => (
            <a 
              href={link.href} 
              class="text-xs font-black uppercase tracking-wider text-zinc-400 hover:text-gold transition-colors py-1 px-2 border border-transparent hover:border-zinc-800 rounded-lg bg-zinc-950/20"
            >
              {link.label}
            </a>
          ))}
        </nav>

      </div>
    </header>

    <main class="flex-grow">
      <slot />
    </main>

    <footer class="border-t border-zinc-900 py-8 text-center text-[10px] text-zinc-600 font-mono uppercase tracking-widest bg-black">
      &copy; {new Date().getFullYear()} Official Nugzz Crew System Terminal. All Rights Reserved.
    </footer>

    <script is:inline>
      // Initialize Lucide Icons globally across template loads safely
      if (window.lucide) {
        window.lucide.createIcons();
      }
    </script>
  </body>
</html>