---
interface Props {
  title: string;
}

const { title } = Astro.props;
import '../styles/global.css'; 

const socials = [
  { name: 'YouTube', url: 'https://www.youtube.com/c/OfficialNugzzCrew', si: 'si-youtube' },
  { name: 'Twitch', url: 'https://www.twitch.tv/officialnugzzcrew', si: 'si-twitch' },
  { name: 'Kick', url: 'https://kick.com/officialnugzzcrew', si: 'si-kick' }, 
  { name: 'Discord', url: 'https://discord.gg/officialnugzzcrew', si: 'si-discord' },
  { name: 'TikTok', url: 'https://www.tiktok.com/@officialnugzzcrew', si: 'si-tiktok' },
  { name: 'Instagram', url: 'https://www.instagram.com/officialnugzzcrew', si: 'si-instagram' },
  { name: 'X', url: 'https://x.com/NugzzCrew', si: 'si-x' },
  { name: 'Facebook', url: 'https://www.facebook.com/nugzzcrew', si: 'si-facebook' },
  { name: 'Snapchat', url: 'https://www.snapchat.com/add/nugzzcrew', si: 'si-snapchat' },
  { name: 'Shop', url: 'https://officialnugzzcrew-shop.fourthwall.com', lucide: 'shopping-bag' },
  { name: 'Crew', url: 'https://socialclub.rockstargames.com/crew/official_nugzz_crew', lucide: 'users' },
];
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <title>{title} | Official Nugzz Crew</title>
        <meta name="viewport" content="width=device-width" />
        <script src="https://unpkg.com/lucide@latest"></script>
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/simple-icons-font@v10/font/simple-icons.min.css" />
    </head>
    <body class="bg-black text-white">
        <nav class="sticky top-0 z-50 bg-black/90 backdrop-blur-md border-b border-zinc-800 p-4">
            <!-- Updated Container: 3-column grid for perfect alignment -->
            <div class="max-w-7xl mx-auto grid grid-cols-3 items-center">
                
                <!-- 1. LEFT: Logo and Branding -->
                <div class="flex justify-start">
                    <a href="/" class="flex items-center gap-4 group hover:opacity-90 transition-opacity">
                        <img src="/Logo.png" alt="Official Nugzz Crew Logo" class="w-10 h-10 object-contain" />
                        <span class="hidden lg:block text-xl font-header text-gold uppercase tracking-tighter group-hover:text-gold-bright transition-colors">
                            Official Nugzz Crew
                        </span>
                    </a>
                </div>

                <!-- 2. CENTER: Navigation Links -->
                <div class="flex justify-center gap-8 text-xs uppercase font-bold tracking-widest text-zinc-400">
                    <a href="/" class="hover:text-gold transition-colors">Home</a>
                    <a href="/gta" class="hover:text-gold transition-colors">GTA Weekly</a>
                </div>

                <!-- 3. RIGHT: Social Icons -->
                <div class="flex justify-end gap-3 flex-wrap">
                    {socials.map((social) => (
                        <a 
                            href={social.url} 
                            target="_blank" 
                            rel="noopener noreferrer" 
                            title={social.name}
                            class="hover:scale-110 transition-transform"
                        >
                            {social.si ? (
                                <i class={`si ${social.si} text-lg text-zinc-400 hover:text-gold transition-colors`}></i>
                            ) : (
                                <i data-lucide={social.lucide} class="w-5 h-5 text-zinc-400 hover:text-gold transition-colors"></i>
                            )}
                        </a>
                    ))}
                </div>

            </div>
        </nav>
        
        <main>
            <slot /> 
        </main>

        <footer class="p-10 text-center text-zinc-600 text-xs border-t border-zinc-900 mt-20">
            &copy; 2026 Official Nugzz Crew | Built for The Fam Bam
        </footer>

        <script>
          // @ts-ignore
          lucide.createIcons();
        </script>
    </body>
</html>