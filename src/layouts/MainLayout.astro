---
// If you have any frontmatter imports, keep them here
const { title = "Nugzz Crew Terminal" } = Astro.props;

// Centralized navigation items for easy future expansion
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/gta', label: 'GTA Bonuses' },
  { href: '/generator', label: 'DMO Gen' },
  { href: '/gtaresources', label: 'Gun Van' },
  // Future expansion lines go right here:
  // { href: '/fo76', label: 'Fallout 76' },
];
---

<!DOCTYPE html>
<html lang="en" class="bg-black text-white selection:bg-gold selection:text-black">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <script src="https://unpkg.com/lucide@latest"></script>
  </head>
  <body class="min-h-screen bg-black antialiased flex flex-col font-sans">
    
    <header class="sticky top-0 z-50 w-full border-b border-zinc-800 bg-black/80 backdrop-blur-md">
      <div class="max-w-7xl mx-auto px-4 h-16 flex items-center justify-between">
        
        <a href="/" class="flex items-center gap-2 group">
          <span class="font-header font-black text-xl tracking-tighter text-white uppercase group-hover:text-gold transition-colors">
            NUGZZ<span class="text-gold group-hover:text-white transition-colors">CREW</span>
          </span>
        </a>

        <nav class="hidden md:flex items-center gap-6">
          {navLinks.map(link => (
            <a 
              href={link.href} 
              class="text-xs font-bold uppercase tracking-wider text-zinc-400 hover:text-gold transition-colors"
            >
              {link.label}
            </a>
          ))}
        </nav>

        <button 
          id="mobileMenuToggle"
          class="md:hidden p-2 text-zinc-400 hover:text-white transition-colors focus:outline-none"
          aria-label="Toggle Navigation Menu"
        >
          <svg id="hamburgerIcon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="closeIcon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>

      </div>

      <div 
        id="mobileMenuDrawer" 
        class="hidden md:hidden border-t border-zinc-900 bg-black/95 px-4 py-6 space-y-4 shadow-2xl transition-all duration-300 ease-in-out"
      >
        <nav class="flex flex-col gap-4">
          {navLinks.map(link => (
            <a 
              href={link.href} 
              class="text-sm font-black uppercase tracking-widest text-zinc-300 hover:text-gold py-2 border-b border-zinc-900/50 block transition-colors"
            >
              {link.label}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <main class="flex-grow">
      <slot />
    </main>

    <footer class="border-t border-zinc-900 py-6 text-center text-[10px] text-zinc-600 font-mono uppercase tracking-widest">
      &copy; {new Date().getFullYear()} Official Nugzz Crew System Terminal. All Rights Reserved.
    </footer>

    <script is:inline>
      function initNavigationToggle() {
        const toggleBtn = document.getElementById('mobileMenuToggle');
        const menuDrawer = document.getElementById('mobileMenuDrawer');
        const hamburgerIcon = document.getElementById('hamburgerIcon');
        const closeIcon = document.getElementById('closeIcon');

        if (!toggleBtn || !menuDrawer) return;

        toggleBtn.addEventListener('click', () => {
          const isHidden = menuDrawer.classList.contains('hidden');
          
          if (isHidden) {
            // Reveal drawer container smoothly
            menuDrawer.classList.remove('hidden');
            hamburgerIcon.classList.add('hidden');
            closeIcon.classList.remove('hidden');
          } else {
            // Hide menu drawer completely
            menuDrawer.classList.add('hidden');
            hamburgerIcon.classList.remove('hidden');
            closeIcon.classList.add('hidden');
          }
        });
      }

      // Initialize on initial page hits and subsequent script caching updates
      window.addEventListener('load', initNavigationToggle);
      document.addEventListener('astro:page-load', initNavigationToggle);
      
      // Initialize Lucide Icons globally across templates if present
      if (window.lucide) {
        window.lucide.createIcons();
      }
    </script>
  </body>
</html>