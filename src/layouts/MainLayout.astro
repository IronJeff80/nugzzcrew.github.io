---
interface Props {
  title: string;
}

const { title } = Astro.props;
import '../styles/global.css'; 

const socials = [
  { name: 'YouTube', url: 'https://www.youtube.com/c/OfficialNugzzCrew', si: 'si-youtube' },
  { name: 'Twitch', url: 'https://www.twitch.tv/officialnugzzcrew', si: 'si-twitch' },
  { name: 'Kick', url: 'https://kick.com/officialnugzzcrew', si: 'si-kick' }, 
  { name: 'Discord', url: 'https://discord.gg/officialnugzzcrew', si: 'si-discord' },
  { name: 'TikTok', url: 'https://www.tiktok.com/@officialnugzzcrew', si: 'si-tiktok' },
  { name: 'Instagram', url: 'https://www.instagram.com/officialnugzzcrew', si: 'si-instagram' },
  { name: 'X', url: 'https://x.com/NugzzCrew', si: 'si-x' },
  { name: 'Facebook', url: 'https://www.facebook.com/nugzzcrew', si: 'si-facebook' },
  { name: 'Snapchat', url: 'https://www.snapchat.com/add/nugzzcrew', si: 'si-snapchat' },
  { name: 'Shop', url: 'https://officialnugzzcrew-shop.fourthwall.com', lucide: 'shopping-bag' },
  { name: 'Crew', url: 'https://socialclub.rockstargames.com/crew/official_nugzz_crew', lucide: 'users' },
];
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <title>{title} | Official Nugzz Crew</title>
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        
        <!-- Favicon Link -->
        <link rel="icon" type="image/png" href="/Logo.png" />
        
        <!-- Icons -->
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/simple-icons-font@v10/font/simple-icons.min.css" />
        <script src="https://unpkg.com/lucide@latest"></script>
    </head>
    <body class="bg-black text-white">
        <nav class="sticky top-0 z-50 bg-black/95 backdrop-blur-md border-b border-zinc-800 p-4">
            <div class="max-w-7xl mx-auto flex flex-col items-center gap-4 md:grid md:grid-cols-3 md:gap-0">
                
                <!-- 1. Branding -->
                <div class="flex md:justify-start w-full justify-center">
                    <a href="/" class="flex items-center gap-3 group hover:opacity-90 transition-opacity">
                        <img src="/Logo.png" alt="Official Nugzz Crew Logo" class="w-8 h-8 md:w-10 md:h-10 object-contain" />
                        <span class="text-lg md:text-xl font-header text-gold uppercase tracking-tighter group-hover:text-gold-bright transition-colors whitespace-nowrap">
                            Official Nugzz Crew
                        </span>
                    </a>
                </div>

                <!-- 2. Navigation -->
                <div class="flex justify-center gap-6 text-[10px] md:text-xs uppercase font-bold tracking-[0.2em] text-zinc-400">
                    <a href="/" class="hover:text-gold transition-colors">Home</a>
                    <a href="/gta" class="hover:text-gold transition-colors">GTA Bonuses</a>
                </div>

                <!-- 3. Social Icons (Centered on mobile, Right on desktop) -->
                <div class="flex justify-center md:justify-end gap-3 flex-wrap w-full">
                    {socials.map((social) => (
                        <a 
                            href={social.url} 
                            target="_blank" 
                            rel="noopener noreferrer" 
                            title={social.name}
                            /* Added 'group' here so the icons inside can react to the hover */
                            class="group hover:scale-110 active:scale-95 transition-all flex items-center justify-center p-1"
                        >
                            <div class="w-5 h-5 md:w-6 md:h-6 flex items-center justify-center pointer-events-none">
                                {social.si ? (
                                    /* group-hover:text-gold ensures color changes when the 'a' tag is hovered */
                                    <i class={`si ${social.si} text-sm md:text-base text-zinc-400 group-hover:text-gold transition-colors`}></i>
                                ) : (
                                    <i data-lucide={social.lucide} class="w-4 h-4 md:w-5 md:h-5 text-zinc-400 group-hover:text-gold transition-colors"></i>
                                )}
                            </div>
                        </a>
                    ))}
                </div>

            </div>
        </nav>
        
        <main>
            <slot /> 
        </main>

        <footer class="p-10 text-center text-zinc-600 text-[10px] md:text-xs border-t border-zinc-900 mt-20">
            &copy; 2026 Official Nugzz Crew | Built for The Fam Bam
        </footer>

        <script is:inline>
          function initIcons() {
            if (window.lucide) {
              window.lucide.createIcons();
            }
          }
          window.addEventListener('load', initIcons);
          document.addEventListener('astro:page-load', initIcons);
        </script>
    </body>
</html>

<style is:global>
    .si {
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        line-height: 1 !important;
    }

    /* Keep icons visible while loading */
    [data-lucide] {
        display: inline-block;
        min-width: 1rem;
        min-height: 1rem;
    }
</style>