---
interface Props {
  title: string;
}

const { title } = Astro.props;
import '../styles/global.css'; 

const socials = [
  { name: 'YouTube', url: 'https://www.youtube.com/c/OfficialNugzzCrew', si: 'si-youtube' },
  { name: 'Twitch', url: 'https://www.twitch.tv/officialnugzzcrew', si: 'si-twitch' },
  { name: 'Kick', url: 'https://kick.com/officialnugzzcrew', si: 'si-kick' }, 
  { name: 'Discord', url: 'https://discord.gg/officialnugzzcrew', si: 'si-discord' },
  { name: 'TikTok', url: 'https://www.tiktok.com/@officialnugzzcrew', si: 'si-tiktok' },
  { name: 'Instagram', url: 'https://www.instagram.com/officialnugzzcrew', si: 'si-instagram' },
  { name: 'X', url: 'https://x.com/NugzzCrew', si: 'si-x' },
  { name: 'Facebook', url: 'https://www.facebook.com/nugzzcrew', si: 'si-facebook' },
  { name: 'Snapchat', url: 'https://www.snapchat.com/add/nugzzcrew', si: 'si-snapchat' },
  { name: 'Shop', url: 'https://officialnugzzcrew-shop.fourthwall.com', lucide: 'shopping-bag' },
  { name: 'Crew', url: 'https://socialclub.rockstargames.com/crew/official_nugzz_crew', lucide: 'users' },
];
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <title>{title} | Official Nugzz Crew</title>
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        
        <link rel="icon" type="image/png" href="/Logo.png" />
        
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/simple-icons-font@v10/font/simple-icons.min.css" />
        <script src="https://unpkg.com/lucide@latest"></script>
    </head>
    <body class="bg-black text-white">
        <nav class="sticky top-0 z-50 bg-black/95 backdrop-blur-md border-b border-zinc-800 p-3 md:p-4">
            <div class="max-w-7xl mx-auto flex flex-col items-center gap-3 md:grid md:grid-cols-3 md:gap-0">
                
                <!-- 1. Branding: Scaled text for mobile -->
                <div class="flex md:justify-start w-full justify-center">
                    <a href="/" class="flex items-center gap-2 md:gap-3 group hover:opacity-90 transition-opacity">
                        <img src="/Logo.png" alt="Official Nugzz Crew Logo" class="w-6 h-6 md:w-10 md:h-10 object-contain" />
                        <span class="text-sm sm:text-base md:text-xl font-header text-gold uppercase tracking-tighter group-hover:text-gold-bright transition-colors whitespace-nowrap">
                            Official Nugzz Crew
                        </span>
                    </a>
                </div>

                <!-- 2. Navigation & Membership Link -->
                <div class="flex flex-col items-center gap-2">
                    <div class="flex justify-center gap-4 md:gap-6 text-[9px] md:text-xs uppercase font-bold tracking-[0.15em] md:tracking-[0.2em] text-zinc-400">
                        <a href="/" class="hover:text-gold transition-colors">Home</a>
                        <a href="/gta" class="hover:text-gold transition-colors">GTA Bonuses</a>
                    </div>
                    <!-- Membership Text: Responsive sizing and centering -->
                    <a href="https://www.youtube.com/c/OfficialNugzzCrew/join" target="_blank" class="text-[8px] md:text-[10px] text-gold-bright hover:underline uppercase tracking-widest font-black text-center px-2">
                        Join The Fam Bam Membership
                    </a>
                </div>

                <!-- 3. Social Icons: Tightened for mobile screens -->
                <div class="flex justify-center md:justify-end gap-1.5 md:gap-3 w-full overflow-hidden">
                    {socials.map((social) => (
                        <a 
                            href={social.url} 
                            target="_blank" 
                            rel="noopener noreferrer" 
                            title={social.name}
                            class="group hover:scale-110 active:scale-95 transition-all flex items-center justify-center"
                        >
                            <div class="w-4 h-4 sm:w-5 sm:h-5 md:w-6 md:h-6 flex items-center justify-center pointer-events-none">
                                {social.si ? (
                                    <i class={`si ${social.si} text-[10px] sm:text-sm md:text-base text-zinc-400 group-hover:text-gold transition-colors`}></i>
                                ) : (
                                    <i data-lucide={social.lucide} class="w-3 h-3 sm:w-4 sm:h-4 md:w-5 md:h-5 text-zinc-400 group-hover:text-gold transition-colors"></i>
                                )}
                            </div>
                        </a>
                    ))}
                </div>

            </div>
        </nav>
        
        <main>
            <slot /> 
        </main>

        <footer class="p-10 text-center text-zinc-600 text-[10px] md:text-xs border-t border-zinc-900 mt-20">
            &copy; 2026 Official Nugzz Crew | Built for The Fam Bam
        </footer>

        <script is:inline>
          function initIcons() {
            if (window.lucide) {
              window.lucide.createIcons();
            }
          }
          window.addEventListener('load', initIcons);
          document.addEventListener('astro:page-load', initIcons);
        </script>
    </body>
</html>

<style is:global>
    .si {
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        line-height: 1 !important;
    }

    [data-lucide] {
        display: inline-block;
        vertical-align: middle;
    }

    /* Prevent horizontal scrolling on mobile */
    body {
        overflow-x: hidden;
    }
</style>