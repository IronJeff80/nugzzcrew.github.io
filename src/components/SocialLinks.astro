---
const socials = [
  { name: 'YouTube', url: 'https://www.youtube.com/c/OfficialNugzzCrew', si: 'si-youtube' },
  { name: 'Twitch', url: 'https://www.twitch.tv/officialnugzzcrew', si: 'si-twitch' },
  { name: 'Kick', url: 'https://kick.com/officialnugzzcrew', si: 'si-kick' }, 
  { name: 'Discord', url: 'https://discord.gg/officialnugzzcrew', si: 'si-discord' },
  { name: 'TikTok', url: 'https://www.tiktok.com/@officialnugzzcrew', si: 'si-tiktok' },
  { name: 'Instagram', url: 'https://www.instagram.com/officialnugzzcrew', si: 'si-instagram' },
  { name: 'X', url: 'https://x.com/NugzzCrew', si: 'si-x' },
  { name: 'Facebook', url: 'https://www.facebook.com/nugzzcrew', si: 'si-facebook' },
  { name: 'Snapchat', url: 'https://www.snapchat.com/add/nugzzcrew', si: 'si-snapchat' },
  { name: 'Shop', url: 'https://officialnugzzcrew-shop.fourthwall.com', lucide: 'shopping-bag' },
  { name: 'Crew', url: 'https://socialclub.rockstargames.com/crew/official_nugzz_crew', lucide: 'users' },
];
---

<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4 my-12">
  {socials.map((social) => (
    <a 
      href={social.url} 
      target="_blank" 
      rel="noopener noreferrer"
      class="flex flex-col items-center justify-between p-6 bg-zinc-900/50 border border-zinc-800 rounded-xl hover:border-gold hover:bg-zinc-900 transition-all group aspect-square lg:aspect-auto lg:h-32"
    >
      <!-- MANDATORY ICON ALIGNMENT BOX -->
      <div class="flex-1 flex items-center justify-center w-full min-h-[40px]">
        {social.si ? (
          /* Using inline-flex and leading-none to kill font-baseline offsets */
          <span class="inline-flex items-center justify-center leading-none">
             <i class={`si ${social.si} text-2xl text-zinc-500 group-hover:text-gold transition-colors`}></i>
          </span>
        ) : (
          /* Lucide Icons forced to match the visual weight of 2xl fonts */
          <i data-lucide={social.lucide} class="w-7 h-7 text-zinc-500 group-hover:text-gold transition-colors"></i>
        )}
      </div>

      <!-- TEXT LABEL -->
      <span class="text-[10px] uppercase text-zinc-500 group-hover:text-gold font-bold tracking-widest text-center mt-auto leading-none">
        {social.name}
      </span>
    </a>
  ))}
</div>

<style>
  /* This ensures Simple Icons don't have extra "descender" space below them */
  .si {
    display: inline-block;
    line-height: 1;
    vertical-align: middle;
  }
</style>